"""
app/parser.py

CT-200 PDF Parser

Responsible for:

- Loading the PDF
- Extracting text blocks
- Preserving reading order
- Preparing blocks for hierarchy reconstruction
- Creating parser metadata

Hierarchy reconstruction and database persistence
are implemented in later sections.
"""

from __future__ import annotations

import logging
from dataclasses import dataclass
from pathlib import Path
from typing import Any

import fitz  # PyMuPDF
from sqlalchemy.orm import Session

from app.models import Document, DocumentVersion
from app.utils import (
    compute_content_hash,
    normalize_heading,
    normalize_text,
)

logger = logging.getLogger(__name__)


# ============================================================
# Data Classes
# ============================================================


@dataclass(slots=True)
class TextBlock:
    """
    Represents one extracted block from the PDF.
    """

    page: int
    text: str
    bbox: tuple[float, float, float, float]
    font_size: float
    font_name: str
    is_bold: bool


@dataclass(slots=True)
class ParsedPage:
    """
    Represents one parsed page.
    """

    page_number: int
    blocks: list[TextBlock]


# ============================================================
# Parser
# ============================================================


class CT200Parser:
    """
    Specialized parser for the CT-200 manuals.

    This parser intentionally targets the
    formatting characteristics of the CT-200 PDFs
    rather than attempting to support arbitrary PDFs.
    """

    def __init__(
        self,
        pdf_path: str | Path,
        db: Session,
    ) -> None:

        self.pdf_path = Path(pdf_path)
        self.db = db

        self.document: fitz.Document | None = None

        self.pages: list[ParsedPage] = []

        logger.info("Parser initialized for %s", self.pdf_path)

    # ========================================================
    # PDF Loading
    # ========================================================

    def open(self) -> None:
        """
        Open PDF using PyMuPDF.
        """

        if not self.pdf_path.exists():
            raise FileNotFoundError(self.pdf_path)

        self.document = fitz.open(self.pdf_path)

        logger.info(
            "Opened PDF with %d pages",
            self.document.page_count,
        )

    def close(self) -> None:
        """
        Close PDF.
        """

        if self.document:
            self.document.close()

    # ========================================================
    # Metadata
    # ========================================================

    def document_title(self) -> str:
        """
        Read document title.

        Falls back to filename.
        """

        if self.document is None:
            raise RuntimeError("PDF not opened.")

        meta = self.document.metadata

        title = meta.get("title")

        if title:
            return normalize_text(title)

        return self.pdf_path.stem

    # ========================================================
    # Extraction
    # ========================================================

    def extract_pages(self) -> list[ParsedPage]:
        """
        Extract all text blocks while preserving
        reading order.
        """

        if self.document is None:
            raise RuntimeError("PDF not opened.")

        parsed_pages: list[ParsedPage] = []

        for page_index, page in enumerate(self.document):

            blocks: list[TextBlock] = []

            data = page.get_text("dict")

            for block in data["blocks"]:

                if "lines" not in block:
                    continue

                text_parts: list[str] = []

                font_size = 0.0
                font_name = ""

                bold = False

                for line in block["lines"]:

                    for span in line["spans"]:

                        value = span["text"].strip()

                        if not value:
                            continue

                        text_parts.append(value)

                        font_size = max(
                            font_size,
                            span["size"],
                        )

                        font_name = span["font"]

                        if "Bold" in span["font"]:
                            bold = True

                text = normalize_text(" ".join(text_parts))

                if not text:
                    continue

                blocks.append(
                    TextBlock(
                        page=page_index + 1,
                        text=text,
                        bbox=tuple(block["bbox"]),
                        font_size=font_size,
                        font_name=font_name,
                        is_bold=bold,
                    )
                )

            parsed_pages.append(
                ParsedPage(
                    page_number=page_index + 1,
                    blocks=blocks,
                )
            )

        self.pages = parsed_pages

        logger.info(
            "Extracted %d pages",
            len(parsed_pages),
        )

        return parsed_pages

    # ========================================================
    # Helpers
    # ========================================================

    def total_pages(self) -> int:

        if self.document is None:
            return 0

        return self.document.page_count

    def total_blocks(self) -> int:

        return sum(
            len(page.blocks)
            for page in self.pages
        )

    def all_blocks(self) -> list[TextBlock]:
        """
        Flatten every page into one ordered list.
        """

        blocks: list[TextBlock] = []

        for page in self.pages:
            blocks.extend(page.blocks)

        return blocks

