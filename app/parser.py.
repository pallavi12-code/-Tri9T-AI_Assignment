# ========================================================
# Heading Detection
# ========================================================

    def detect_headings(self) -> list[dict[str, Any]]:
        """
        Detect headings using multiple heuristics.

        Unlike a generic parser, this logic is tuned for the CT-200
        manuals and intentionally combines typography with textual
        patterns instead of relying on only font size.

        Returns
        -------
        List[dict]
            Each dictionary contains metadata describing one heading.
        """

        if not self.pages:
            raise RuntimeError("Pages have not been extracted.")

        heading_candidates: list[dict[str, Any]] = []

        blocks = self.all_blocks()

        if not blocks:
            return heading_candidates

        # Build statistics for adaptive thresholds
        font_sizes = sorted({b.font_size for b in blocks})

        max_font = max(font_sizes)
        min_font = min(font_sizes)

        logger.info(
            "Detected font size range %.1f - %.1f",
            min_font,
            max_font,
        )

        for index, block in enumerate(blocks):

            text = normalize_text(block.text)

            if not text:
                continue

            score = 0

            # --------------------------------------------------
            # Typography
            # --------------------------------------------------

            if block.is_bold:
                score += 2

            if block.font_size >= max_font:
                score += 3

            elif block.font_size >= max_font - 1:
                score += 2

            elif block.font_size >= max_font - 2:
                score += 1

            # --------------------------------------------------
            # Numbered headings
            # --------------------------------------------------

            if self._looks_numbered(text):
                score += 3

            # --------------------------------------------------
            # Very short lines are likely headings
            # --------------------------------------------------

            words = len(text.split())

            if words <= 8:
                score += 1

            # --------------------------------------------------
            # Sentences ending with "." usually aren't headings
            # --------------------------------------------------

            if text.endswith("."):
                score -= 2

            # --------------------------------------------------
            # Store candidate
            # --------------------------------------------------

            if score >= 3:

                heading_candidates.append(
                    {
                        "index": index,
                        "text": text,
                        "normalized": normalize_heading(text),
                        "font_size": block.font_size,
                        "page": block.page,
                        "score": score,
                        "bbox": block.bbox,
                    }
                )

        logger.info(
            "Detected %d heading candidates",
            len(heading_candidates),
        )

        return heading_candidates

    # ========================================================
    # Hierarchy Reconstruction
    # ========================================================

    def reconstruct_hierarchy(
        self,
        headings: list[dict[str, Any]],
    ) -> list[dict[str, Any]]:
        """
        Reconstruct parent-child relationships.

        Uses a stack-based hierarchy algorithm.

        Handles:

        - duplicate headings
        - skipped heading levels
        - out-of-order heading depths
        """

        hierarchy: list[dict[str, Any]] = []

        stack: list[dict[str, Any]] = []

        for heading in headings:

            level = self._estimate_level(
                heading["font_size"]
            )

            heading["level"] = level

            while stack and stack[-1]["level"] >= level:
                stack.pop()

            if stack:
                heading["parent"] = stack[-1]["normalized"]
            else:
                heading["parent"] = None

            stack.append(heading)

            hierarchy.append(heading)

        logger.info(
            "Hierarchy reconstructed (%d headings)",
            len(hierarchy),
        )

        return hierarchy

    # ========================================================
    # Internal Helpers
    # ========================================================

    def _estimate_level(
        self,
        font_size: float,
    ) -> int:
        """
        Estimate heading level from font size.

        This intentionally uses coarse buckets rather than exact
        values because PDFs often vary slightly between pages.
        """

        if font_size >= 18:
            return 1

        if font_size >= 16:
            return 2

        if font_size >= 14:
            return 3

        if font_size >= 12:
            return 4

        return 5

    def _looks_numbered(
        self,
        text: str,
    ) -> bool:
        """
        Detect numbered headings.

        Examples:

        1

        2.1

        3.4.5

        Appendix A
        """

        import re

        if re.match(r"^\d+(\.\d+)*", text):
            return True

        if text.lower().startswith("appendix"):
            return True

        return False

    def validate_hierarchy(
        self,
        hierarchy: list[dict[str, Any]],
    ) -> None:
        """
        Emit warnings for suspicious hierarchy jumps.
        """

        previous_level = 1

        for heading in hierarchy:

            level = heading["level"]

            if level - previous_level > 1:

                logger.warning(
                    "Skipped heading level detected: %s",
                    heading["text"],
                )

            previous_level = level
# ========================================================
# Tree Construction
# ========================================================

    def build_tree(
        self,
        hierarchy: list[dict[str, Any]],
    ) -> list["Node"]:
        """
        Build SQLAlchemy Node objects from the reconstructed hierarchy.

        This stage only builds the in-memory tree.
        Database persistence happens later.
        """

        from app.models import Node

        nodes: list[Node] = []

        parent_lookup: dict[str, Node] = {}

        order_counter = 1

        for item in hierarchy:

            heading = item["text"]
            normalized = item["normalized"]

            parent_heading = item["parent"]

            parent_node = None

            if parent_heading:
                parent_node = parent_lookup.get(parent_heading)

            structural_path = self._generate_structural_path(
                parent_node,
                order_counter,
            )

            node = Node(
                version_id=0,  # Updated during persistence
                parent=parent_node,
                order_index=order_counter,
                level=item["level"],
                heading=heading,
                content_text="",
                content_hash="",
                structural_path=structural_path,
            )

            nodes.append(node)

            parent_lookup[normalized] = node

            order_counter += 1

        logger.info(
            "Created %d in-memory nodes",
            len(nodes),
        )

        return nodes

# ========================================================
# Attach Body Text
# ========================================================

    def attach_content(
        self,
        nodes: list["Node"],
        hierarchy: list[dict[str, Any]],
    ) -> None:
        """
        Attach paragraph content to every heading.

        Every heading owns all text until the next heading.
        """

        blocks = self.all_blocks()

        heading_lookup = {
            item["index"]: node
            for item, node in zip(hierarchy, nodes)
        }

        heading_indices = sorted(heading_lookup.keys())

        for current, block_index in enumerate(heading_indices):

            node = heading_lookup[block_index]

            if current == len(heading_indices) - 1:
                next_index = len(blocks)
            else:
                next_index = heading_indices[current + 1]

            collected: list[str] = []

            for block in blocks[block_index + 1 : next_index]:

                text = normalize_text(block.text)

                if not text:
                    continue

                collected.append(text)

            node.content_text = "\n".join(collected)

            node.content_hash = compute_content_hash(
                node.heading + "\n" + node.content_text
            )

# ========================================================
# Structural Path
# ========================================================

    def _generate_structural_path(
        self,
        parent,
        order_index: int,
    ) -> str:
        """
        Generate deterministic structural paths.

        Examples

        0001

        0001/0002

        0001/0002/0003
        """

        current = f"{order_index:04d}"

        if parent is None:
            return current

        return f"{parent.structural_path}/{current}"

# ========================================================
# Root Detection
# ========================================================

    def find_root(
        self,
        nodes: list["Node"],
    ):
        """
        Return the first top-level node.
        """

        for node in nodes:

            if node.parent is None:
                return node

        return None

# ========================================================
# Statistics
# ========================================================

    def tree_statistics(
        self,
        nodes: list["Node"],
    ) -> dict[str, int]:
        """
        Return lightweight parser statistics.
        """

        total = len(nodes)

        roots = sum(
            1 for n in nodes if n.parent is None
        )

        leaves = sum(
            1 for n in nodes if len(n.children) == 0
        )

        return {
            "total_nodes": total,
            "root_nodes": roots,
            "leaf_nodes": leaves,
        }
