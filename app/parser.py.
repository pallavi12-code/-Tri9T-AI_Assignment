# Part 3B - Persistence Layer

from sqlalchemy.orm import Session
from app.models import Document, Node


class CT200Parser:

    # existing Part 1, Part 2, Part 3A methods remain here


    def save_document(
        self,
        db: Session,
        filename: str,
        metadata: dict,
        root_nodes: list
    ):
        """
        Persist parsed CT200 document and node hierarchy
        into database.
        """

        document = Document(
            filename=filename,
            title=metadata.get("title", filename),
            page_count=metadata.get("page_count", 0)
        )

        db.add(document)
        db.flush()


        for root in root_nodes:
            self._save_node(
                db=db,
                node=root,
                document_id=document.id,
                parent_id=None
            )


        db.commit()

        return document



    def _save_node(
        self,
        db: Session,
        node,
        document_id: int,
        parent_id=None
    ):
        """
        Recursive node persistence.
        """

        db_node = Node(
            document_id=document_id,
            parent_id=parent_id,
            title=node.title,
            level=node.level,
            node_type=node.node_type,
            content=node.content,
            structural_path=node.structural_path,
            content_hash=node.content_hash
        )

        db.add(db_node)
        db.flush()


        for child in node.children:

            self._save_node(
                db=db,
                node=child,
                document_id=document_id,
                parent_id=db_node.id
            )


        return db_node



    def load_document_tree(
        self,
        db: Session,
        document_id: int
    ):
        """
        Retrieve stored document hierarchy.
        """

        root_nodes = (
            db.query(Node)
            .filter(
                Node.document_id == document_id,
                Node.parent_id == None
            )
            .all()
        )

        return root_nodes



    def delete_document(
        self,
        db: Session,
        document_id: int
    ):
        """
        Remove document and all associated nodes.
        """

        nodes = (
            db.query(Node)
            .filter(
                Node.document_id == document_id
            )
            .all()
        )

        for node in nodes:
            db.delete(node)


        document = (
            db.query(Document)
            .filter(
                Document.id == document_id
            )
            .first()
        )


        if document:
            db.delete(document)


        db.commit()

        return True
"""
versioning.py

Handles CT200 document version management,
comparison, and change detection.
"""

from datetime import datetime
import hashlib
from typing import List, Dict


class DocumentVersionManager:
    """
    Maintains different versions of parsed documents
    and detects structural/content changes.
    """


    def generate_hash(self, text: str) -> str:
        """
        Generate unique hash for content comparison.
        """

        if not text:
            text = ""

        return hashlib.sha256(
            text.encode("utf-8")
        ).hexdigest()



    def create_version_record(
        self,
        document_id: int,
        filename: str,
        sections: list
    ):
        """
        Creates metadata for a new document version.
        """

        version_hash = self.generate_hash(
            "".join(
                [
                    section.content or ""
                    for section in sections
                ]
            )
        )


        return {
            "document_id": document_id,
            "filename": filename,
            "version_hash": version_hash,
            "created_at": datetime.utcnow(),
            "section_count": len(sections)
        }



    def compare_versions(
        self,
        old_sections: List,
        new_sections: List
    ) -> Dict:
        """
        Compare two parsed document trees.
        """

        old_map = self._create_section_map(
            old_sections
        )

        new_map = self._create_section_map(
            new_sections
        )


        changes = {

            "added": [],
            "removed": [],
            "modified": []

        }


        # Detect added sections

        for key in new_map:

            if key not in old_map:

                changes["added"].append(
                    {
                        "section": key,
                        "content": new_map[key]
                    }
                )



        # Detect removed sections

        for key in old_map:

            if key not in new_map:

                changes["removed"].append(
                    {
                        "section": key,
                        "content": old_map[key]
                    }
                )



        # Detect modifications

        for key in old_map:

            if key in new_map:

                old_hash = self.generate_hash(
                    old_map[key]
                )

                new_hash = self.generate_hash(
                    new_map[key]
                )


                if old_hash != new_hash:

                    changes["modified"].append(
                        {
                            "section": key,
                            "old_content": old_map[key],
                            "new_content": new_map[key]
                        }
                    )


        return changes



    def _create_section_map(
        self,
        sections: list
    ) -> Dict:
        """
        Convert tree structure into dictionary
        for comparison.
        """

        section_map = {}


        for section in sections:

            path = getattr(
                section,
                "structural_path",
                section.title
            )


            section_map[path] = (
                section.content or ""
            )


            children = getattr(
                section,
                "children",
                []
            )


            if children:

                child_map = self._create_section_map(
                    children
                )

                section_map.update(
                    child_map
                )


        return section_map



    def generate_change_summary(
        self,
        changes: Dict
    ):
        """
        Generate human-readable report.
        """

        summary = {

            "total_changes": (
                len(changes["added"])
                +
                len(changes["removed"])
                +
                len(changes["modified"])
            ),

            "added_sections":
                len(changes["added"]),

            "removed_sections":
                len(changes["removed"]),

            "modified_sections":
                len(changes["modified"])

        }


        return summary
