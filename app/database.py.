# app/database.py
"""Database configuration module.

Provides the SQLAlchemy engine, session factory, declarative base, and a
FastAPI dependency (`get_db`) for request-scoped sessions. All other
modules that touch the relational store (models.py, routes.py, etc.)
import `Base` and `get_db` from here — this file has no internal
dependencies on the rest of the app, by design, so it can be imported
first without circular-import risk.
"""

import os
from collections.abc import Generator

from sqlalchemy import create_engine
from sqlalchemy.engine import Engine
from sqlalchemy.orm import DeclarativeBase, Session, sessionmaker

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
DATABASE_URL: str = os.getenv("DATABASE_URL", "sqlite:///./tri9t.db")

_connect_args: dict[str, bool] = (
    {"check_same_thread": False} if DATABASE_URL.startswith("sqlite") else {}
)

# ---------------------------------------------------------------------------
# Engine
# ---------------------------------------------------------------------------
engine: Engine = create_engine(
    DATABASE_URL,
    connect_args=_connect_args,
    pool_pre_ping=True,
    future=True,
)

# ---------------------------------------------------------------------------
# Session factory
# ---------------------------------------------------------------------------
SessionLocal: sessionmaker[Session] = sessionmaker(
    bind=engine,
    autoflush=True,
    expire_on_commit=False,
    future=True,
)


# ---------------------------------------------------------------------------
# Declarative base
# ---------------------------------------------------------------------------
class Base(DeclarativeBase):
    """Base class for all ORM models in the application."""


# ---------------------------------------------------------------------------
# FastAPI dependency
# ---------------------------------------------------------------------------
def get_db() -> Generator[Session, None, None]:
    """Yield a request-scoped SQLAlchemy session.

    Intended for use as a FastAPI dependency via `Depends(get_db)`. The
    session is always closed after the request completes, whether or not
    an exception was raised, to avoid leaking connections back to the pool
    in an inconsistent state.
    """
    db: Session = SessionLocal()
    try:
        yield db
    finally:
        db.close()
